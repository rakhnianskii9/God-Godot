{
  "inputs": [],
  "servers": {
    "crash": {
      "command": "npx",
      "args": [
        "-y",
        "crash-mcp"
      ],
      "env": {
        "MAX_HISTORY_SIZE": "999999999999999999",
        "CRASH_STRICT_MODE": "false",
        "CRASH_OUTPUT_FORMAT": "console"
      },
      "type": "stdio"
    },
    "context7": {
      "command": "npx",
      "args": [
        "-y",
        "@upstash/context7-mcp"
      ],
      "env": {
        "CONTEXT7_API_KEY": "${env:CONTEXT7_API_KEY}"
      },
      "type": "stdio"
    },
    "octocode": {
      "command": "npx",
      "args": [
        "-y",
        "octocode-mcp@latest"
      ],
      "env": {
        "NPM_CONFIG_UPDATE_NOTIFIER": "false",
        "NPM_CONFIG_FUND": "false",
        "NPM_CONFIG_AUDIT": "false",
        "NPM_CONFIG_LOGLEVEL": "silent"
      },
      "type": "stdio"
    },
    "godot-coding-solo": {
      "command": "npx",
      "args": [
        "-y",
        "@coding-solo/godot-mcp"
      ],
      "type": "stdio"
    },
    "godot-tomyud1": {
      "command": "npx",
      "args": [
        "-y",
        "godot-mcp-server"
      ],
      "type": "stdio"
    },
    "rpg-game-server": {
      "command": "npx",
      "args": [
        "-y",
        "rpg-mcp-server"
      ],
      "env": {
        "NODE_ENV": "production"
      },
      "type": "stdio"
    }
  }
}
