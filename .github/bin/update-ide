#!/usr/bin/env bash
# Назначение: синхронизация IDE/артефактов: проверка наличия .github/context/*
# и журналирование простых метаданных. Можно расширить интеграцией в MCP memory.
set -euo pipefail

ROOT="/home/projects/new-flowise"
CTX_DIR="$ROOT/.github/context"
DOCKER_ENV="$ROOT/docker/.env"
ROOT_ENV="$ROOT/.env"

log(){ printf '%s\n' "$@"; }
err(){ printf '%s\n' "$@" >&2; }

log "[update-ide] verifying context artifacts..."
missing=()
for f in db-schema.json migrations.json entities.json dynamic-conditions.json; do
  [[ -f "$CTX_DIR/$f" ]] || missing+=("$f")
done
if (( ${#missing[@]} > 0 )); then
  err "[update-ide] missing: ${missing[*]}"
else
  log "[update-ide] all required artifacts present"
fi

DB_URL="${POSTGRES_URL_RO:-${DATABASE_URL:-${DATABASE_URI:-}}}"
DB_URL_LOCAL=""
SEARCH_DIRS=("$ROOT/packages")
if [[ -z "$DB_URL" && -f "$DOCKER_ENV" ]]; then
  DB_URL=$(grep -E '^(POSTGRES_URL_RO|DATABASE_URL|DATABASE_URI)=' "$DOCKER_ENV" | tail -n 1 | cut -d '=' -f2- || true)
  if [[ -z "$DB_URL" ]]; then
    db_host=$(grep -E '^DATABASE_HOST=' "$DOCKER_ENV" | tail -n 1 | cut -d '=' -f2- || true)
    db_port=$(grep -E '^DATABASE_PORT=' "$DOCKER_ENV" | tail -n 1 | cut -d '=' -f2- || true)
    db_name=$(grep -E '^DATABASE_NAME=' "$DOCKER_ENV" | tail -n 1 | cut -d '=' -f2- || true)
    db_user=$(grep -E '^DATABASE_USER=' "$DOCKER_ENV" | tail -n 1 | cut -d '=' -f2- || true)
    db_pass=$(grep -E '^DATABASE_PASSWORD=' "$DOCKER_ENV" | tail -n 1 | cut -d '=' -f2- || true)
    if [[ -n "$db_host" && -n "$db_port" && -n "$db_name" && -n "$db_user" && -n "$db_pass" ]]; then
      DB_URL="postgresql://$db_user:$db_pass@$db_host:$db_port/$db_name"
      if [[ "$db_host" == "postgres" ]]; then
        DB_URL_LOCAL="postgresql://$db_user:$db_pass@localhost:$db_port/$db_name"
      fi
    fi
  fi
fi
if [[ -z "$DB_URL" && -f "$ROOT_ENV" ]]; then
  db_host=$(grep -E '^DATABASE_HOST=' "$ROOT_ENV" | tail -n 1 | cut -d '=' -f2- || true)
  db_port=$(grep -E '^DATABASE_PORT=' "$ROOT_ENV" | tail -n 1 | cut -d '=' -f2- || true)
  db_name=$(grep -E '^DATABASE_NAME=' "$ROOT_ENV" | tail -n 1 | cut -d '=' -f2- || true)
  db_user=$(grep -E '^DATABASE_USER=' "$ROOT_ENV" | tail -n 1 | cut -d '=' -f2- || true)
  db_pass=$(grep -E '^DATABASE_PASSWORD=' "$ROOT_ENV" | tail -n 1 | cut -d '=' -f2- || true)
  if [[ -n "$db_host" && -n "$db_port" && -n "$db_name" && -n "$db_user" && -n "$db_pass" ]]; then
    DB_URL="postgresql://$db_user:$db_pass@$db_host:$db_port/$db_name"
    if [[ "$db_host" == "postgres" ]]; then
      DB_URL_LOCAL="postgresql://$db_user:$db_pass@localhost:$db_port/$db_name"
    fi
  fi
fi

log "[update-ide] running local generation..."
  if [[ -z "$DB_URL" ]]; then
    err "[update-ide] DB URL not set (POSTGRES_URL_RO/DATABASE_URL/DATABASE_URI)"
  elif command -v psql >/dev/null 2>&1; then
    run_psql(){
      local sql="$1"; local out="$2"; local tmp="$2.tmp";
      if psql "$DB_URL" -Atc "$sql" > "$tmp" 2>/dev/null; then mv -f "$tmp" "$out"; return 0; fi
      if [[ -n "$DB_URL_LOCAL" ]] && psql "$DB_URL_LOCAL" -Atc "$sql" > "$tmp" 2>/dev/null; then mv -f "$tmp" "$out"; return 0; fi
      rm -f "$tmp" >/dev/null 2>&1 || true
      return 1
    }

    if ! run_psql "
      with cols as (
        select c.table_schema,c.table_name,c.column_name,c.data_type,c.is_nullable,
               coalesce(c.character_maximum_length,0) as char_len
        from information_schema.columns c
        where c.table_schema not in ('pg_catalog','information_schema')
      ),
      fks as (
        select tc.table_schema,tc.table_name,kcu.column_name,
               ccu.table_schema as ref_schema, ccu.table_name as ref_table, ccu.column_name as ref_column
        from information_schema.table_constraints tc
        join information_schema.key_column_usage kcu
          on tc.constraint_name=kcu.constraint_name and tc.table_schema=kcu.table_schema
        join information_schema.constraint_column_usage ccu
          on ccu.constraint_name=tc.constraint_name and ccu.table_schema=tc.table_schema
        where tc.constraint_type='FOREIGN KEY'
      )
      select jsonb_pretty(jsonb_agg(t order by table_schema, table_name))
      from (
        select
          c.table_schema, c.table_name,
          jsonb_agg(jsonb_build_object(
            'column', c.column_name,
            'type', c.data_type,
            'nullable', (c.is_nullable='YES'),
            'length', c.char_len
          ) order by c.column_name) as columns,
          jsonb_agg(distinct jsonb_build_object(
            'column', f.column_name,
            'ref_schema', f.ref_schema,
            'ref_table', f.ref_table,
            'ref_column', f.ref_column
          )) filter (where f.column_name is not null) as foreign_keys
        from cols c
        left join fks f
          on f.table_schema=c.table_schema and f.table_name=c.table_name and f.column_name=c.column_name
        group by c.table_schema, c.table_name
      ) t;
    " "$CTX_DIR/db-schema.json"; then
      err "[update-ide] DB schema export failed"
    fi

    if run_psql "
      select 1 from information_schema.tables where table_schema='public' and table_name='dynamic_conditions' limit 1;
    " "$CTX_DIR/.dynamic-conditions.exists"; then
      if [[ ! -s "$CTX_DIR/.dynamic-conditions.exists" ]]; then
        echo "[]" > "$CTX_DIR/dynamic-conditions.json"
        err "[update-ide] dynamic_conditions table missing; wrote empty list"
      else
        if ! run_psql "
          select jsonb_pretty(coalesce(jsonb_agg(t),'[]'::jsonb)) from (
            select key, engine, is_active, rule, description
            from public.dynamic_conditions
            order by key
          ) t;
        " "$CTX_DIR/dynamic-conditions.json"; then
          err "[update-ide] export dynamic_conditions failed"
        fi
      fi
    else
      echo "[]" > "$CTX_DIR/dynamic-conditions.json"
      err "[update-ide] dynamic_conditions table missing; wrote empty list"
    fi
    rm -f "$CTX_DIR/.dynamic-conditions.exists" >/dev/null 2>&1 || true
  else
    err "[update-ide] psql not found"
  fi

  if command -v rg >/dev/null 2>&1 && command -v jq >/dev/null 2>&1; then
    rg --json -n --color never -e '(^\s*CREATE\s+TABLE|^\s*ALTER\s+TABLE|^\s*CREATE\s+INDEX|^\s*ADD\s+COLUMN|^\s*DROP\s+COLUMN)' \
      "${SEARCH_DIRS[@]}" 2>/dev/null \
    | jq -sr 'map({file:.data.path.text,line:(.data.line_number//0),text:.data.lines.text})' \
    > "$CTX_DIR/migrations.json" || err "[update-ide] rg migrations failed"

    rg --json -n --color never -e '(Entity\(|model\s+|Prisma\.|@Entity|@Schema|export\s+class\s+\w+)' \
      "${SEARCH_DIRS[@]}" 2>/dev/null \
    | jq -sr 'map({file:.data.path.text,line:(.data.line_number//0),text:.data.lines.text})' \
    > "$CTX_DIR/entities.json" || err "[update-ide] rg entities failed"
  else
    err "[update-ide] rg/jq not found"
  fi

# Простейший штамп времени
echo "[update-ide] timestamp: $(date -Iseconds)" > "$CTX_DIR/.last-update-ide.txt"
echo "[update-ide] done"

# Лёгкая синхронизация KB-хэшей (для трассировки):
DATA_DIR="$ROOT/.github/mcp/data"
if [[ -d "$DATA_DIR" ]]; then
  mem_file="$DATA_DIR/memory.jsonl"
  kg_file="$DATA_DIR/knowledge-graph.jsonl"
  ctx7_file="$DATA_DIR/context7.jsonl"
  ts=$(date -Iseconds)
  mem_hash=$(command -v sha256sum >/dev/null 2>&1 && { sha256sum "$mem_file" 2>/dev/null | awk '{print $1}'; } || echo "")
  kg_hash=$(command -v sha256sum >/dev/null 2>&1 && { sha256sum "$kg_file" 2>/dev/null | awk '{print $1}'; } || echo "")
  if [[ -n "$mem_hash" || -n "$kg_hash" ]]; then
    line=$(printf '{"type":"kb-sync","ts":"%s","memoryHash":"%s","kgHash":"%s"}\n' "$ts" "${mem_hash:-}" "${kg_hash:-}")
    printf '%s' "$line" >> "$ctx7_file" || true
    echo "[update-ide] kb-sync recorded"
  fi
fi
