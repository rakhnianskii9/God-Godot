{
	"inputs": [],
	"servers": {
		"crash": {
			"command": "npx",
			"args": [
				"-y",
				"crash-mcp"
			],
			"env": {
				"MAX_HISTORY_SIZE": "999999999999999999",
				"CRASH_STRICT_MODE": "false",
				"CRASH_OUTPUT_FORMAT": "console"
			},
			"type": "stdio"
		},
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp"
			],
			"env": {
				"CONTEXT7_API_KEY": "${env:CONTEXT7_API_KEY}"
			},
			"type": "stdio"
		},
		"octocode": {
			"command": "npx",
			"args": [
				"-y",
				"octocode-mcp@latest"
			],
			"env": {
				"NPM_CONFIG_UPDATE_NOTIFIER": "false",
				"NPM_CONFIG_FUND": "false",
				"NPM_CONFIG_AUDIT": "false",
				"NPM_CONFIG_LOGLEVEL": "silent"
			},
			"type": "stdio"
		},
		"filesystem": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"/home/projects/gamedev"
			],
			"type": "stdio"
		},
		"mcp-files": {
			"command": "npx",
			"args": [
				"-y",
				"mcp-files"
			],
			"type": "stdio"
		}
	}
}