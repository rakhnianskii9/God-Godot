{
	"inputs": [
		{
			"id": "memory_file_path",
			"type": "promptString",
			"description": "Path to the memory storage file (optional)",
			"password": false
		}
	],
	"servers": {
		"crash": {
			"command": "npx",
			"args": [
				"-y",
				"crash-mcp"
			],
			"env": {
				"MAX_HISTORY_SIZE": "999999999999999999",
				"CRASH_STRICT_MODE": "false",
				"CRASH_OUTPUT_FORMAT": "console"
			},
			"type": "stdio"
		},
		"task-manager": {
			"command": "npx",
			"args": [
				"-y",
				"mcp-tasks"
			],
			"env": {
				"TASKS_FILE": "/home/projects/new-flowise/.github/tasks.md"
			},
			"type": "stdio"
		},
		"memory": {
			"command": "/home/projects/new-flowise/.github/mcp/venv-memory/bin/memory-server",
			"args": [],
			"env": {
				"MCP_MEMORY_STORAGE_BACKEND": "sqlite_vec",
				"MCP_MEMORY_SQLITE_PATH": "/home/projects/new-flowise/.github/mcp/data/sqlite_vec.db",
				"MCP_MEMORY_CHROMA_PATH": "/home/projects/new-flowise/.github/mcp/data/chroma",
				"MCP_MEMORY_BACKUPS_PATH": "/home/projects/new-flowise/.github/mcp/data/backups"
			},
			"type": "stdio"
		},
		"filesystem": {
			"command": "npx",
			"args": [
				"-y",
				"@modelcontextprotocol/server-filesystem",
				"/home/projects/new-flowise",
				"/home/projects/new-flowise/packages",
				"/home/projects/new-flowise/nginx"
			],
			"type": "stdio"
		},
		"playwright": {
			"command": "npx",
			"args": [
				"-y",
				"@playwright/mcp",
				"--headless"
			],
			"type": "stdio"
		},
		"chrome-devtools": {
			"command": "npx",
			"args": [
				"-y",
				"chrome-devtools-mcp",
				"--headless",
				"--isolated"
			],
			"type": "stdio"
		},
		"octocode": {
			"command": "npx",
			"args": [
				"-y",
				"octocode-mcp@latest"
			],
			"type": "stdio"
		},
		"apify": {
			"url": "https://mcp.apify.com",
			"type": "http"
		},
		"context7": {
			"command": "npx",
			"args": [
				"-y",
				"@upstash/context7-mcp"
			],
			"env": {
				"CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}"
			},
			"type": "stdio"
		},
		"mcp-files": {
			"command": "npx",
			"args": [
				"-y",
				"mcp-files"
			],
			"type": "stdio"
		},
		"mcpvault": {
			"command": "npx",
			"args": [
				"-y",
				"@bitbonsai/mcpvault@latest",
				"/Volumes/v-rh@bk.ru/Obsidian"
			],
			"type": "stdio"
		},
		"github": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/",
			"headers": {
				"X-MCP-Toolsets": "repos,issues,pull_requests,actions,code_security,dependabot,discussions,secret_protection,security_advisories,notifications,orgs,projects,gists,git,labels,users,stargazers"
			}
		},
		"github-support-docs": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/x/github_support_docs_search"
		},
		"github-copilot": {
			"type": "http",
			"url": "https://api.githubcopilot.com/mcp/x/copilot"
		}
	}
}